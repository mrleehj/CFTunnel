# Cloudflare Tunnel Manager - 环境变量配置示例
# 复制此文件为 .env 并根据需要修改

# 运行环境
NODE_ENV=production

# 服务端口
PORT=3000

# 数据目录（容器内路径）
DATA_DIR=/data

# JWT 密钥（可选，不设置会自动生成）
# JWT_SECRET=your-secret-key-here

# 日志级别 (error, warn, info, debug)
LOG_LEVEL=info

# cloudflared 版本（可选，不设置使用最新版）
# CLOUDFLARED_VERSION=2024.1.5

# 下载镜像源（可选）
# DOWNLOAD_MIRROR=https://ghfast.top
