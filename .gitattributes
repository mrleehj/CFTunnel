# 确保 shell 脚本使用 LF 换行符
*.sh text eol=lf
*.bash text eol=lf

# 确保 JavaScript 文件使用 LF 换行符
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# 确保配置文件使用 LF 换行符
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Markdown 文件
*.md text eol=lf

# 其他文本文件
*.txt text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
